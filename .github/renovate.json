{
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "prHourlyLimit": 4,
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "gomodVendor"
  ],
  "ignorePaths": [
    "vendor/**/Dockerfile",
    "vendor/**/requirements.txt"
  ],
  "packageRules": [
    {
      "description": "Enable security only bumps for release branches",
      "enabled": false,
      "matchBaseBranches": [
        "release/v5.5",
        "release/v5.4"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true
}
